{
  "name": "cc-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "dev:server": "pnpm -C server dev",
    "dev:client": "pnpm -C client dev",
    "typecheck": "pnpm -C server typecheck && pnpm -C client typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "sh scripts/install-hooks.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
