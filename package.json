{
  "name": "cc-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "npm install --prefix server && npm install --prefix client",
    "dev": "bash scripts/dev.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "typecheck": "npm run typecheck --prefix server && npm run typecheck --prefix client",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "sh scripts/install-hooks.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
